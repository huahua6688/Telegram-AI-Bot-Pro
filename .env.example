# =========================
# Telegram
# =========================
BOT_TOKEN=your_telegram_bot_token

# Telegram Mini App（BotFather 可把菜单 URL 指向 https://你的域名/app）
MINI_APP_ENABLED=true
MINI_APP_AUTH_MAX_AGE_SECONDS=3600

# =========================
# Default AI settings
# =========================
DEFAULT_AI_PROVIDER=auto
DEFAULT_AI_MODEL=gemini-2.5-flash

ENABLE_USER_PROVIDER_SELECTION=true
ENABLE_USER_MODEL_SELECTION=true

ENABLE_PROVIDER_FALLBACK=true
# Cross-provider fallback requires a separate API key for every provider used here.
AI_PROVIDER_FALLBACK_ORDER=gemini,groq,openrouter
# Extra retries after the first failed request (1 means at most 2 attempts per model).
AI_PROVIDER_MAX_RETRIES=1
AI_PROVIDER_RETRY_DELAY_MS=800
AI_PROVIDER_COOLDOWN_MS=60000
MODEL_LIST_CACHE_TTL_MS=3600000

# Backward-compatible legacy single-provider selector.
AI_PROVIDER=

# =========================
# Google Gemini
# =========================
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# =========================
# Gemini Live
# =========================
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_LIVE_MODEL=
GEMINI_LIVE_TRANSCRIPTION_MODEL=
GEMINI_LIVE_TTS_MODEL=
# Keep disabled unless GEMINI_LIVE_API_KEY and compatible Live models are configured.
ENABLE_LIVE_AUDIO=false
ENABLE_LIVE_TRANSLATE=false
ENABLE_VIDEO=false

# =========================
# OpenAI-compatible providers
# Copy current model IDs from each official console. Do not guess.
# =========================
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b,llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=poolside/laguna-xs-2.1:free,cohere/north-mini-code:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Telegram AI Bot Pro

GITHUB_MODELS_API_KEY=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=
GITHUB_MODELS_FALLBACK_MODELS=

HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_MODEL=
HUGGINGFACE_FALLBACK_MODELS=

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=
MISTRAL_FALLBACK_MODELS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_FALLBACK_MODELS=

# Generic custom OpenAI-compatible gateway.
# Use provider id openai-compatible for this one.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_FALLBACK_MODELS=

# =========================
# Native providers
# =========================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_MODEL=
ANTHROPIC_FALLBACK_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=
DEEPSEEK_FALLBACK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=
QWEN_FALLBACK_MODELS=

GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=
GROK_FALLBACK_MODELS=

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=
GLM_FALLBACK_MODELS=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=
DOUBAO_FALLBACK_MODELS=

# =========================
# Dedicated capability providers
# =========================
TRANSLATION_PROVIDER=gemini
TRANSLATION_MODEL=gemini-2.5-flash-lite
ROUTER_PROVIDER=gemini
ROUTER_MODEL=gemini-2.5-flash-lite
MEMORY_PROVIDER=gemini
MEMORY_MODEL=gemini-2.5-flash-lite
VISION_PROVIDER=gemini
VISION_MODEL=gemini-2.5-flash
TRANSCRIPTION_PROVIDER=gemini-live
TRANSCRIPTION_MODEL=
TTS_PROVIDER=gemini-live
TTS_MODEL=
IMAGE_PROVIDER=openai-compatible
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024
TTS_VOICE=alloy

# =========================
# AI Router / Memory
# =========================
ENABLE_AI_ROUTER=false
AI_ROUTER_MODE=single-pass
ENABLE_MEMORY_SUMMARY=true
MEMORY_SUMMARY_INTERVAL=5

# =========================
# Prompt / Generation
# =========================
AI_SYSTEM_PROMPT=You are a powerful Telegram AI assistant. Answer helpfully and concisely.
AI_TEMPERATURE=0.6
AI_MAX_TOOL_STEPS=3

# =========================
# Image / Document
# =========================
DOCUMENT_MAX_BYTES=6291456
DOCUMENT_MAX_CHARS=12000
DOCUMENT_CHUNK_CHARS=1800

# =========================
# Tools
# =========================
ENABLE_TOOL_CALLS=true
ENABLE_WEB_SEARCH=true
ENABLE_GEMINI_GOOGLE_SEARCH=true
ENABLE_URL_FETCH=true
# Recommended for stable web search; the keyless fallback is best-effort only.
BRAVE_SEARCH_API_KEY=
TOOL_ALLOWED_NAMES=get_time,get_weather,fetch_url,web_search
TOOL_ALLOWED_USER_IDS=
TOOL_ALLOWED_CHAT_IDS=
TOOL_BLOCKED_USER_IDS=
TOOL_ADMIN_ONLY_NAMES=
TOOL_MAX_CALLS_PER_MESSAGE=4
TOOL_USER_WINDOW_MS=60000
TOOL_USER_MAX_CALLS=20
NETWORK_TOOL_SCOPE=all
NETWORK_TOOL_ALLOWED_USER_IDS=
NETWORK_TOOL_ALLOWED_CHAT_IDS=

# =========================
# Storage / Zeabur
# =========================
DATABASE_FILE=/data/bot-data.db
DATA_FILE=/data/bot-data.json
PORT=8080
HEALTH_PORT=8080

# =========================
# Limits
# =========================
ENABLE_STREAMING_REPLIES=true
STREAMING_EDIT_INTERVAL_MS=350
STREAMING_MIN_LENGTH=160
MAX_HISTORY_MESSAGES=32
MAX_CONTEXT_CHARS=48000
MAX_INPUT_CHARS=12000
MAX_OUTPUT_CHARS=3500
REQUEST_TIMEOUT_MS=120000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=12
DAILY_QUOTA=200

# =========================
# Telegram Stars / usage billing
# Prices and package grants are deployment configuration; the application has
# no built-in paid price. Keep this JSON on one line in your hosting panel.
# Credit keys: chat, vision, image_generation, tts, live_voice, video.
# =========================
STARS_PAYMENTS_ENABLED=true
STARS_PRODUCTS_JSON=[{"id":"starter","title":"入门额度包","titleEn":"Starter credits","description":"聊天、图片和语音综合额度","descriptionEn":"Credits for chat, images and voice","price":50,"credits":{"chat":200,"vision":20,"image_generation":5,"tts":20,"live_voice":10,"video":0}}]
STARS_FREE_CHAT_DAILY=20
STARS_FREE_VISION_DAILY=3
STARS_FREE_IMAGE_DAILY=1
STARS_FREE_TTS_DAILY=2
STARS_FREE_LIVE_VOICE_DAILY=2
STARS_FREE_VIDEO_DAILY=0
STARS_ORDER_TTL_MINUTES=60
STARS_USAGE_RESERVATION_TTL_MINUTES=15
STARS_REFUND_LEASE_SECONDS=300
STARS_TERMS_TEXT=
STARS_SUPPORT_TEXT=

# =========================
# Admin
# =========================
ADMIN_API_ENABLED=false
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=/admin/api/v1
ADMIN_API_TOKEN=
ADMIN_USER_IDS=
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=
BLOCKED_USER_IDS=

# =========================
# Group
# =========================
GROUP_TRIGGER_MODE=smart
GROUP_TRIGGER_KEYWORD=ai

# =========================
# Telegram platform modes
# Enable Inline, Guest, Guard, Secretary, and Bot-to-Bot modes in BotFather too.
# =========================
ENABLE_SECRETARY_AUTO_REPLY=true
# Guard 初始模式：queue=审核、approve=开放、decline=严格；管理员可在 Bot 内切换并持久化
GUARD_DEFAULT_ACTION=queue
BOT_COLLABORATION_COOLDOWN_MS=5000
INLINE_QUERY_DEBOUNCE_MS=1200
# 少于此字符数的内联输入只提示继续输入，不请求搜索或 AI，也不扣额度
INLINE_QUERY_MIN_CHARS=2
INLINE_QUERY_RESPONSE_TIMEOUT_MS=8000
INLINE_QUERY_SEARCH_TIMEOUT_MS=2300
INLINE_QUERY_AI_ATTEMPT_TIMEOUT_MS=2200
INLINE_QUERY_CACHE_TTL_MS=60000
# Google News RSS 地区、语言和“当天”日期边界（默认马来西亚，UTC+8）
NEWS_REGION=MY
# auto 跟随用户保存的语言；也可固定为 zh-CN、zh-TW、en 等
NEWS_LANGUAGE=auto
NEWS_TIME_ZONE=Asia/Kuala_Lumpur
