BOT_TOKEN=your_telegram_bot_token
# AI_PROVIDER: openai-compatible | anthropic | gemini | gemini-live | qwen | grok | deepseek | glm | doubao
AI_PROVIDER=openai-compatible
# 必须使用 AI_API_KEY（不是 OPENAI_API_KEY）
AI_API_KEY=your_ai_api_key
# 这是 OpenAI 兼容接口地址。可替换为 OpenRouter / 其他兼容网关
AI_BASE_URL=https://api.openai.com/v1
# Anthropic 直连可设置 ANTHROPIC_API_KEY（不填则复用 AI_API_KEY）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
# Gemini 直连可设置 GEMINI_API_KEY（不填则复用 AI_API_KEY）
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Gemini Live 原生接入（不填则分别复用 GEMINI_API_KEY / GEMINI_BASE_URL）
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Qwen 通义千问直连
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_VERSION=
# Grok (xAI) 直连
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_API_VERSION=
# DeepSeek 直连
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_VERSION=
# 智谱 GLM 直连
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_VERSION=
# 豆包（火山引擎 Ark）直连
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_VERSION=
# 模型名必须与 AI_BASE_URL 对应的提供商一致
AI_MODEL=gpt-4.1-mini
AI_FALLBACK_MODELS=gpt-4.1-mini,gpt-4o-mini
# SQLite 数据库文件
DATABASE_FILE=/data/bot-data.db
# 兼容旧版 lowdb JSON 数据导入；首次启动会自动迁移
DATA_FILE=/data/bot-data.json
AI_SYSTEM_PROMPT=You are a powerful Telegram AI assistant. Answer helpfully and concisely.
AI_TEMPERATURE=0.6
AI_MAX_TOOL_STEPS=3
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
GEMINI_LIVE_TRANSCRIPTION_MODEL=
GEMINI_LIVE_TTS_MODEL=
TTS_VOICE=alloy
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024
DOCUMENT_MAX_BYTES=6291456
DOCUMENT_MAX_CHARS=12000
DOCUMENT_CHUNK_CHARS=1800
ENABLE_TOOL_CALLS=true
ENABLE_WEB_SEARCH=true
ENABLE_URL_FETCH=true
TOOL_ALLOWED_NAMES=get_time,fetch_url,web_search
TOOL_ALLOWED_USER_IDS=
TOOL_ALLOWED_CHAT_IDS=
TOOL_BLOCKED_USER_IDS=
TOOL_ADMIN_ONLY_NAMES=
TOOL_MAX_CALLS_PER_MESSAGE=4
TOOL_USER_WINDOW_MS=60000
TOOL_USER_MAX_CALLS=20
NETWORK_TOOL_SCOPE=all
NETWORK_TOOL_ALLOWED_USER_IDS=
NETWORK_TOOL_ALLOWED_CHAT_IDS=
ENABLE_LIVE_AUDIO=true
ENABLE_LIVE_TRANSLATE=true
ENABLE_STREAMING_REPLIES=true
STREAMING_EDIT_INTERVAL_MS=350
STREAMING_MIN_LENGTH=160
MAX_HISTORY_MESSAGES=16
MAX_INPUT_CHARS=12000
MAX_OUTPUT_CHARS=3500
REQUEST_TIMEOUT_MS=120000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=12
DAILY_QUOTA=200
HEALTH_PORT=8080
ADMIN_API_ENABLED=true
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=/admin/api/v1
ADMIN_API_TOKEN=
ADMIN_USER_IDS=
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=
BLOCKED_USER_IDS=
GROUP_TRIGGER_MODE=smart
GROUP_TRIGGER_KEYWORD=ai

# Translation
TRANSLATION_MODEL=gemini-2.5-flash-lite
