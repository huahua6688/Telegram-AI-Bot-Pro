# =========================
# Telegram
# =========================
BOT_TOKEN=your_telegram_bot_token

# =========================
# AI Provider
# 推荐 Zeabur + Gemini 免费版先用 gemini
# AI_PROVIDER: openai-compatible | anthropic | gemini | gemini-live | qwen | grok | deepseek | glm | doubao
# =========================
AI_PROVIDER=gemini

# 通用 API Key。多数 provider 可复用这个。
AI_API_KEY=

# Gemini 直连
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI-compatible / OpenRouter / 其他兼容网关
AI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01

# Gemini Live 原生接入
# 不填则复用 GEMINI_API_KEY / GEMINI_BASE_URL
GEMINI_LIVE_API_KEY=
GEMINI_LIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Qwen 通义千问
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_VERSION=

# Grok / xAI
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_API_VERSION=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_VERSION=

# GLM / 智谱
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_VERSION=

# Doubao / 火山 Ark
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_VERSION=

# =========================
# Models
# Gemini 免费额度有限，建议主模型 + 备用模型
# =========================
AI_MODEL=gemini-2.5-flash
AI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash-lite

# 翻译和意图 Router 用轻量模型，省额度
TRANSLATION_MODEL=gemini-2.5-flash-lite
ROUTER_MODEL=gemini-2.5-flash-lite

# =========================
# AI Router / Memory
# =========================
ENABLE_AI_ROUTER=true
AI_ROUTER_MODE=smart

ENABLE_MEMORY_SUMMARY=true
MEMORY_SUMMARY_INTERVAL=5

# =========================
# Prompt / Generation
# =========================
AI_SYSTEM_PROMPT=You are a powerful Telegram AI assistant. Answer helpfully and concisely.
AI_TEMPERATURE=0.6
AI_MAX_TOOL_STEPS=3

# =========================
# Audio / Live / TTS
# 注意：Gemini 普通 generateContent 不等于 Gemini Live。
# Gemini Live 需要单独实现/启用。
# =========================
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
GEMINI_LIVE_TRANSCRIPTION_MODEL=
GEMINI_LIVE_TTS_MODEL=
TTS_VOICE=alloy
ENABLE_LIVE_AUDIO=false
ENABLE_LIVE_TRANSLATE=false

# =========================
# Image / Document
# =========================
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024

DOCUMENT_MAX_BYTES=6291456
DOCUMENT_MAX_CHARS=12000
DOCUMENT_CHUNK_CHARS=1800

# =========================
# Tools
# =========================
ENABLE_TOOL_CALLS=true
ENABLE_WEB_SEARCH=true
ENABLE_URL_FETCH=true
TOOL_ALLOWED_NAMES=get_time,fetch_url,web_search
TOOL_ALLOWED_USER_IDS=
TOOL_ALLOWED_CHAT_IDS=
TOOL_BLOCKED_USER_IDS=
TOOL_ADMIN_ONLY_NAMES=
TOOL_MAX_CALLS_PER_MESSAGE=4
TOOL_USER_WINDOW_MS=60000
TOOL_USER_MAX_CALLS=20
NETWORK_TOOL_SCOPE=all
NETWORK_TOOL_ALLOWED_USER_IDS=
NETWORK_TOOL_ALLOWED_CHAT_IDS=

# =========================
# Storage / Zeabur
# Zeabur 挂载目录建议 /data
# =========================
DATABASE_FILE=/data/bot-data.db
DATA_FILE=/data/bot-data.json

# Zeabur HTTP Port
PORT=8080
HEALTH_PORT=8080

# =========================
# Limits
# =========================
ENABLE_STREAMING_REPLIES=true
STREAMING_EDIT_INTERVAL_MS=350
STREAMING_MIN_LENGTH=160

MAX_HISTORY_MESSAGES=16
MAX_INPUT_CHARS=12000
MAX_OUTPUT_CHARS=3500

REQUEST_TIMEOUT_MS=120000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=12
DAILY_QUOTA=200

# =========================
# Admin
# =========================
ADMIN_API_ENABLED=true
ADMIN_API_PORT=3001
ADMIN_API_PREFIX=/admin/api/v1
ADMIN_API_TOKEN=

ADMIN_USER_IDS=
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=
BLOCKED_USER_IDS=

# =========================
# Group
# =========================
GROUP_TRIGGER_MODE=smart
GROUP_TRIGGER_KEYWORD=ai
