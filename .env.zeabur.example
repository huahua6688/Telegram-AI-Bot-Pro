# Required
BOT_TOKEN=your_BotFather_token
ADMIN_USER_IDS=your_Telegram_user_id

# Default provider
DEFAULT_AI_PROVIDER=gemini
DEFAULT_AI_MODEL=copy_from_google_ai_studio
GEMINI_API_KEY=your_Gemini_API_key
GEMINI_MODEL=copy_from_google_ai_studio
GEMINI_FALLBACK_MODELS=

# Optional free/low-cost fallback providers.
ENABLE_PROVIDER_FALLBACK=true
AI_PROVIDER_FALLBACK_ORDER=gemini,groq,openrouter
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Dedicated capabilities
VISION_PROVIDER=gemini
TRANSLATION_PROVIDER=gemini
TRANSLATION_MODEL=copy_from_google_ai_studio
ROUTER_PROVIDER=gemini
ROUTER_MODEL=copy_from_google_ai_studio
TRANSCRIPTION_PROVIDER=gemini-live
TTS_PROVIDER=gemini-live
IMAGE_PROVIDER=openai-compatible

# Zeabur ports and persistence
PORT=8080
HEALTH_PORT=8080
DATABASE_FILE=/data/bot-data.db
DATA_FILE=/data/bot-data.json

# Features
ENABLE_USER_PROVIDER_SELECTION=true
ENABLE_USER_MODEL_SELECTION=true
ENABLE_AI_ROUTER=true
AI_ROUTER_MODE=smart
ENABLE_MEMORY_SUMMARY=true
MEMORY_SUMMARY_INTERVAL=5
ENABLE_LIVE_AUDIO=false
ENABLE_LIVE_TRANSLATE=false
ENABLE_TOOL_CALLS=true
ENABLE_WEB_SEARCH=true
ENABLE_GEMINI_GOOGLE_SEARCH=true
ENABLE_URL_FETCH=true

# Limits
DAILY_QUOTA=200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=12

# Admin API
ADMIN_API_ENABLED=false
