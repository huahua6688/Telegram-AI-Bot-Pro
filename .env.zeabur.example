# Zeabur 必填
BOT_TOKEN=你的_BotFather_Token
AI_PROVIDER=gemini
GEMINI_API_KEY=你的_Gemini_API_Key

AI_MODEL=gemini-3.5-flash
AI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
TRANSLATION_MODEL=gemini-3.1-flash-lite
ROUTER_MODEL=gemini-3.1-flash-lite

ADMIN_USER_IDS=你的_Telegram_User_ID

# Zeabur 推荐
PORT=8080
HEALTH_PORT=8080

DATABASE_FILE=/data/bot-data.db
DATA_FILE=/data/bot-data.json

ENABLE_AI_ROUTER=true
AI_ROUTER_MODE=smart

ENABLE_MEMORY_SUMMARY=true
MEMORY_SUMMARY_INTERVAL=5

ADMIN_API_ENABLED=false

# 可选
ENABLE_LIVE_AUDIO=false
ENABLE_LIVE_TRANSLATE=false

ENABLE_TOOL_CALLS=true
ENABLE_WEB_SEARCH=true
ENABLE_GEMINI_GOOGLE_SEARCH=true
ENABLE_URL_FETCH=true

DAILY_QUOTA=200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=12
